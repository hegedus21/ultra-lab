# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Anthropic Claude API (cikk generáláshoz)
ANTHROPIC_API_KEY=your_anthropic_api_key

# YouTube Data API (opcionális – felirat nélküli tartalmakhoz)
YOUTUBE_API_KEY=your_youtube_api_key

# HTTP proxy a felirat-letöltéshez, hogy a YouTube ne blokkolja a GitHub Actions runner IP-jét
# Formátum: http://username:password@host:port (pl. Webshare.io rotating proxy)
# Ha üresen hagyod, proxy nélkül próbálkozik (helyi fejlesztéshez általában jó)
YT_PROXY_URL=

# Resend (email értesítés review-hoz)
RESEND_API_KEY=your_resend_api_key
REVIEW_EMAIL=your@email.com
